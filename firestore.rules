rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "shshohagh4@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'title', 'createdAt', 'userId']) &&
             data.id is string &&
             isValidString(data.title, 100) &&
             data.userId is string;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp', 'userId']) &&
             data.role in ['user', 'assistant'] &&
             isValidString(data.content, 10000) &&
             data.userId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                       request.resource.data.role == resource.data.role) || isAdmin();
      
      // Chat Sessions
      match /chats/{chatId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidChat(request.resource.data) && request.resource.data.userId == userId;
        allow update: if (isOwner(userId) && isValidChat(request.resource.data) && request.resource.data.userId == userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();

        // Messages within a Session
        match /messages/{messageId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isValidMessage(request.resource.data) && request.resource.data.userId == userId;
          allow update: if isAdmin();
          allow delete: if isAdmin();
        }
      }
    }
  }
}
